PORT=3847
# Local: use `memory` (needs devDependencies installed) or a real MongoDB URI.
# Vercel: set MONGODB_URI to MongoDB Atlas (SRV) in the Vercel dashboard — `memory` is not supported there.
MONGODB_URI=memory
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/spinwheel_promo?retryWrites=true&w=majority
ADMIN_TOKEN=change-this-to-a-long-random-secret-min-16-chars
# Behind your own reverse proxy (not needed on Vercel; VERCEL=1 enables trust proxy automatically):
# TRUST_PROXY=1
# Optional: absolute path to a custom whitelist file (default: server/allowed_users.txt)
# WHITELIST_PATH=/path/to/allowed_users.txt
# Hide the “Admin” link in the public page footer (admin UI remains at /admin.html)
# SHOW_ADMIN_FOOTER=0
